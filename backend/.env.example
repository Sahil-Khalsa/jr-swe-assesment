# Copy to .env and adjust as needed. Defaults in app/config.py work out of the box for local dev.

# DATABASE_URL=sqlite:///./data/app.db
# To swap to Postgres: DATABASE_URL=postgresql://user:password@host:5432/dbname
# (also add `psycopg2-binary` to requirements.txt)

JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=30

CORS_ORIGINS=["http://localhost:5173"]
